# ── AVA Verification Platform — Environment Variables ─────────────────────────
# Copy this file to .env and fill in the values for your local setup.
# The platform reads these at runtime via python-dotenv.
#
#   cp .env.example .env
#   # then edit .env with your actual paths

# ── RISC-V Toolchain ──────────────────────────────────────────────────────────
# Path to the RISC-V GCC cross-compiler prefix.
# e.g. riscv32-unknown-elf-gcc lives at $RISCV_GCC-gcc
# Common values:
#   Linux (from riscv-gnu-toolchain):  /opt/riscv/bin/riscv32-unknown-elf
#   Conda:  /home/user/miniconda3/envs/riscv/bin/riscv32-unknown-elf
RISCV_GCC=riscv32-unknown-elf

# ── Spike ISS ─────────────────────────────────────────────────────────────────
# Full path to the Spike RISC-V ISA simulator binary.
# Build from source: https://github.com/riscv-software-src/riscv-isa-sim
SPIKE_BIN=spike

# ── Verilator ─────────────────────────────────────────────────────────────────
# Path to Verilator binary (v5.x recommended).
# Build from source: https://github.com/verilator/verilator
VERILATOR_BIN=verilator

# ── Agent B → Agent E bridge ──────────────────────────────────────────────────
# Absolute path to AGENT_B/backends/run_rtl.py
# Used by AGENT_E/run_rtl_adapter.py to locate the RTL runner.
# Example: /home/user/ai-chip-design-platform/AGENT_B/backends/run_rtl.py
AGENT_B_RTL=

# ── Optional: LLM API keys (for ava_patched.py LLM reasoning layer) ──────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional: Database (future distributed mode) ──────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/ava
# REDIS_URL=redis://localhost:6379/0
# MONGODB_URL=mongodb://localhost:27017/ava

# ── Optional: Coverage database path ─────────────────────────────────────────
# Defaults to ./coverage.db in the run directory if not set.
# AVA_COVERAGE_DB=./coverage.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
AVA_LOG_LEVEL=INFO

# Log file path (leave empty to log to stdout only)
# AVA_LOG_FILE=./ava_verification.log
